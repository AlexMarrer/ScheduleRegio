<Window x:Class="PopSimProto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Population Simulation Prototype"
        MinWidth="800" MinHeight="650"
        Width="1400" Height="850"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ==================== TOP BAR (3.2 Simulation + 3.3/3.4 File) ==================== -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Date/Time -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Sim Controls -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SimDateTimeLabel" Text="-- no world loaded --" 
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,12,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStep" Content="+ Step" Style="{StaticResource ToolbarButton}" 
                            Click="BtnStep_Click"/>
                    <Button x:Name="BtnPlayPause" Content="▶ Play" Style="{StaticResource ToolbarButton}" 
                            Click="BtnPlayPause_Click"/>
                </StackPanel>

                <!-- File Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="File" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Open" Style="{StaticResource ToolbarButton}" Click="BtnOpen_Click"/>
                    <Button Content="Save" Style="{StaticResource ToolbarButton}" Click="BtnSave_Click"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                    <Button Content="Exit" Style="{StaticResource ToolbarButton}" Click="BtnExit_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Map -->
                <ColumnDefinition Width="*" MinWidth="300"/>
                <!-- Right Panel: People + Editor + Locations -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="380" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170" MinWidth="140"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 3.1 MAP DISPLAY ========== -->
            <Border Grid.Column="0" Background="#E8F5E9" Margin="4" BorderBrush="#999" BorderThickness="1">
                <!-- Canvas for rendering map; use Viewbox to maintain 1:1 aspect -->
                <Viewbox Stretch="Uniform">
                    <Canvas x:Name="MapCanvas" Width="1000" Height="1000" 
                            Background="#DFF0D8" ClipToBounds="True">
                        <!-- Location and citizen icons are added here programmatically -->
                    </Canvas>
                </Viewbox>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="#CCC"/>

            <!-- ========== RIGHT PANEL (People + Editor) ========== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="People" Style="{StaticResource HeaderLabel}"/>
                <ListBox x:Name="PeopleList" Grid.Row="1" Margin="4,0" 
                         SelectionChanged="PeopleList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" FontFamily="Segoe UI Emoji" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" Text="Selected Person" Style="{StaticResource HeaderLabel}" 
                           Margin="4,8,4,2"/>

                <Border Grid.Row="3" BorderBrush="#CCC" BorderThickness="1" Margin="4,0" Padding="8">
                    <Grid x:Name="CitizenEditorPanel" IsEnabled="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon Button -->
                        <Button x:Name="BtnCitizenIcon" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                FontSize="36" MinWidth="56" MinHeight="56" Margin="0,0,8,0"
                                VerticalAlignment="Top" ToolTip="Select icon">
                            <Button.Content>
                                <ComboBox x:Name="CmbCitizenIcon" FontSize="24" Width="56" Height="36" SelectionChanged="CmbCitizenIcon_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Segoe UI Emoji" FontSize="24"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Button.Content>
                        </Button>

                        <!-- Firstname -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,2">
                            <TextBlock Text="Firstname" FontSize="11" Foreground="Gray"/>
                            <TextBox x:Name="TxtFirstname" TextChanged="CitizenField_Changed"/>
                        </StackPanel>

                        <!-- Lastname -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,2">
                            <TextBlock Text="Lastname" FontSize="11" Foreground="Gray"/>
                            <TextBox x:Name="TxtLastname" TextChanged="CitizenField_Changed"/>
                        </StackPanel>

                        <!-- Home Address -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4">
                            <TextBlock Text="🏠 Home Address" FontSize="11" Foreground="Gray"/>
                            <ComboBox x:Name="CmbHome" DisplayMemberPath="Name"
                                      SelectionChanged="CmbHome_SelectionChanged"/>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4">
                            <TextBlock x:Name="LblStatus" Text="Status: --" FontSize="12" 
                                       FontStyle="Italic" Foreground="#555"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== 3.6.1 SCHEDULE EDITOR ===== -->
                <DockPanel Grid.Row="4" Margin="4,8,4,4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Schedule" Style="{StaticResource HeaderLabel}"/>
                        <Button x:Name="BtnAddSchedule" Content="+ Add" Padding="6,2" Margin="8,0,0,0"
                                Click="BtnAddSchedule_Click"/>
                        <Button x:Name="BtnRemoveSchedule" Content="- Remove" Padding="6,2" Margin="4,0,0,0"
                                Click="BtnRemoveSchedule_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ScheduleGrid" AutoGenerateColumns="False" 
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              SelectionMode="Single" FontSize="12"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              CellEditEnding="ScheduleGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Width="60"
                                Binding="{Binding Time, StringFormat=hh\\:mm}" IsReadOnly="False"/>
                            <DataGridComboBoxColumn Header="Location" Width="*"
                                x:Name="ColScheduleLocation"
                                DisplayMemberPath="Name"
                                SelectedItemBinding="{Binding TargetLocation}"/>
                            <DataGridTextColumn Header="Activity" Width="80"
                                Binding="{Binding Activity}" IsReadOnly="False"/>
                            <DataGridTextColumn Header="Travel" Width="55" IsReadOnly="True"
                                Binding="{Binding TravelTimeDisplay}"/>
                            <DataGridTextColumn Header="Spend" Width="55" IsReadOnly="True"
                                Binding="{Binding SpendTimeDisplay}"/>
                            <DataGridTextColumn Header="Total" Width="55" IsReadOnly="True"
                                Binding="{Binding TotalTimeDisplay}"/>
                        </DataGrid.Columns>

                        <!-- Highlight conflicting rows -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                        <Setter Property="Background" Value="#FFCCCC"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="#CCC"/>

            <!-- ========== 3.7 LOCATION LIST ========== -->
            <DockPanel Grid.Column="4" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="Locations" Style="{StaticResource HeaderLabel}"/>

                <!-- Location Editor (inline, compact) -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" 
                        Padding="4" Margin="0,4,0,0">
                    <StackPanel x:Name="LocationEditorPanel" IsEnabled="False">
                        <!-- Location Icon Auswahl -->
                        <ComboBox x:Name="CmbLocationIcon" FontSize="20" Width="60" Margin="0,0,0,4" SelectionChanged="CmbLocationIcon_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Segoe UI Emoji" FontSize="20"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Name" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="TxtLocationName" Margin="0,0,0,4"
                                 TextChanged="LocationField_Changed"/>
                        <TextBlock Text="X" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="TxtLocationX" Margin="0,0,0,4"
                                 TextChanged="LocationField_Changed"/>
                        <TextBlock Text="Y" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="TxtLocationY" Margin="0,0,0,4"
                                 TextChanged="LocationField_Changed"/>
                    </StackPanel>
                </Border>

                <ListBox x:Name="LocationList" Margin="0,4"
                         SelectionChanged="LocationList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Segoe UI Emoji" FontSize="13">
                                <Run Text="{Binding Icon, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Name, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
